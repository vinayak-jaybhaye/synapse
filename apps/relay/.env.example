# PostgreSQL Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=synapse
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis Configuration
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Outbox Relay Worker Configuration
# If WORKER_PARTITION is set, this process will run only that specific partition (0-15).
# If unset, the process runs all partitions concurrently.
WORKER_PARTITION=
WORKER_COUNT=16
